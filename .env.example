# Copy the values you need into a project-root .env file for docker compose variable
# substitution. This is separate from secrets/.env, which is passed into containers.
FRONTEND_TLS_CERT_PATH=/absolute/path/to/npm/live/centflow/fullchain.pem
FRONTEND_TLS_KEY_PATH=/absolute/path/to/npm/live/centflow/privkey.pem
NPM_EXTERNAL_NETWORK=npm_proxy
